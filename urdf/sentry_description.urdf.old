<?xml version="1.0"?>
<robot name="sentry"
  xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Define robot constants -->
  <xacro:property name="base_radius" value="0.2975" />
  <xacro:property name="base_length" value="0.42" />
  <xacro:property name="base_height" value="0.220" />

  <xacro:property name="wheel_radius" value="0.10" />
  <xacro:property name="wheel_width" value="0.04" />
  <xacro:property name="wheel_ygap" value="0.025" />
  <xacro:property name="wheel_zoff" value="0.05" />
  <xacro:property name="wheel_xoff" value="0.12" />

  <xacro:property name="caster_xoff" value="0.14" />

  <xacro:property name="head_length" value="0.29528" />
  <xacro:property name="head_width" value="0.1524" />
  <xacro:property name="head_height" value="0.18398" />


  <xacro:property name="pitch_turret_length" value="0.15" />
  <xacro:property name="pitch_turret_width" value="0.10" />
  <xacro:property name="pitch_turret_height" value="0.10" />
  <!-- Define some commonly used intertial properties  -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}" />
      <mass value="${m}" />
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" iyy="${(m/12) * (w*w + d*d)}"
        iyz="0.0" izz="${(m/12) * (w*w + h*h)}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
      <mass value="${m}" />
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0" iyy="${(m/12) * (3*r*r + h*h)}"
        iyz="0" izz="${(m/2) * (r*r)}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}" />
      <inertia ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0" iyy="${(2/5) * m * (r*r)}" iyz="0.0"
        izz="${(2/5) * m * (r*r)}" />
    </inertial>
  </xacro:macro>

  <!-- Robot Base -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}" />
      </geometry>
      <material name="Dark_Cyan">
        <color rgba="0 0.8 0.8 0.8" />
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}" />
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0" />
      <inertia ixx="0.0216" ixy="0" ixz="0" iyy="0.0216" iyz="0" izz="0.0416" />
    </inertial>
  </link>

  <!-- Robot Footprint -->
  <link name="base_footprint" />
  <!-- <xacro:cylinder_inertia m="15" r="${base_radius}" h="${base_height}" /> -->

  <joint name="base_joint" type="fixed">
    <parent link="base_link" />
    <child link="base_footprint" />
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
  </joint>

  <!-- Robot Head -->
  <link name="head_link">
    <visual>
      <geometry>
        <box size="${head_length} ${head_width} ${head_height}" />
      </geometry>
      <material name="Cyan">
        <color rgba="0 1.0 1.0 1.0" />
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="${head_length} ${head_width} ${head_height}" />
      </geometry>
    </collision>

    <xacro:box_inertia m="0.05" w="0.05" d="0.05" h="0.05" />
  </link>

  <joint name="head_joint" type="continuous">
    <parent link="base_link" />
    <child link="head_link" />
    <origin xyz="0 0 ${0.3548 - base_height}" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- === Sensors === -->
  <!-- IMU -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </visual>

    <collision>
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </collision>

    <xacro:box_inertia m="0.05" w="0.05" d="0.05" h="0.05" />
  </link>

  <joint name='imu_joint' type='fixed'>
    <parent link="head_link"></parent>
    <child link="imu_link"></child>
    <origin xyz="0 -0.05 -0.05" />
  </joint>

  <!-- lidar -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.125" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0500" length="0.025" />
      </geometry>
    </collision>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0500" length="0.025" />
      </geometry>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="head_link" />
    <child link="lidar_link" />
    <origin xyz="0.12218 -0.17882 0" rpy="0 0 ${pi/2}" />
  </joint>

</robot>
