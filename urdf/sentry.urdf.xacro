<?xml version="1.0"?>
<robot name="sentry" xmlns:xacro="http://ros.org">

  <!-- Define robot constants -->
  <xacro:property name="base_radius" value="0.2975" />
  <xacro:property name="base_height" value="0.220" />
  <xacro:property name="head_length" value="0.29528" />
  <xacro:property name="head_width" value="0.1524" />
  <xacro:property name="head_height" value="0.18398" />

  <!-- Inertial Macros -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="${m}" />
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0"
        iyy="${(m/12) * (w*w + d*d)}" iyz="0.0"
        izz="${(m/12) * (w*w + h*h)}" />
    </inertial>
  </xacro:macro>

  <!-- 1. Robot Footprint (The Ground Reference) -->
  <link name="base_footprint">
  </link>


  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
  </joint>

  <!-- 2. Robot Base (The Cylinder) -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}" />
      </geometry>
      <material name="Dark_Cyan">
        <color rgba="0 0.8 0.8 0.8" />
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}" />
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0" />
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.2" />
    </inertial>
  </link>

  <!-- 3. Robot Head (The Rotating Box) -->
  <joint name="head_joint" type="continuous">
    <parent link="base_link" />
    <child link="head_link" />
    <!-- Centers the head slightly above the top of the base cylinder -->
    <origin xyz="0 0 ${base_height/2 + 0.05}" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <link name="head_link">
    <visual>
      <geometry>
        <box size="${head_length} ${head_width} ${head_height}" />
      </geometry>
      <material name="Cyan">
        <color rgba="0 1.0 1.0 1.0" />
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${head_length} ${head_width} ${head_height}" />
      </geometry>
    </collision>
    <xacro:box_inertia m="0.5" w="${head_width}" h="${head_height}" d="${head_length}" />
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="head_link" />
    <child link="lidar" />
    <origin xyz="0.12218 -0.17882 0" rpy="0 0 ${pi/2}" />
  </joint>
  <link name="lidar">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.04" />
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1" />
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.04" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>
  <gazebo reference="lidar">
    <gz_frame_id>lidar</gz_frame_id>
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>
      <topic>scan</topic>
      <gz_frame_id>lidar</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.000000</resolution>
            <min_angle>0.000000</min_angle>
            <max_angle>6.280000</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.120000</min>
          <max>3.5</max>
          <resolution>0.015000</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>
</robot>
